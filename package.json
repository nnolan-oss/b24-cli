{
  "name": "b24-cli",
  "version": "1.1.0",
  "description": "CLI tool to manage Bitrix24 tasks, comments, time tracking from terminal. Supports multiple languages.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "b24-cli": "dist/cli.js",
    "b24": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "bitrix24",
    "bitrix",
    "cli",
    "tasks",
    "crm",
    "kanban",
    "time-tracking",
    "terminal",
    "ink",
    "react-ink"
  ],
  "author": "Javohir G'ulomjonov <https://nolan.uz> (https://github.com/3nln)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnolan-oss/b24-cli.git"
  },
  "homepage": "https://github.com/nnolan-oss/b24-cli#readme",
  "bugs": {
    "url": "https://github.com/nnolan-oss/b24-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
